	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/joelvoss/in-parallel-lit.git"
	},
	"engines": {
		"node": ">=20"
	},
	"bin": {
		"in-parallel": "dist/bin.js"
	},
