	"scripts": {
		"test": "./Taskfile.sh test",
		"prepublishOnly": "./Taskfile.sh build"
	},
	"dependencies": {
		"cross-spawn": "7.0.6",
		"mri": "1.2.0",
		"sade": "1.8.1"
	},
	"devDependencies": {
		"@types/cross-spawn": "6.0.6",
		"@types/node": "26.0.1",
		"oxfmt": "0.56.0",
		"oxlint": "1.71.0",
		"typescript": "6.0.3",
		"vite": "8.1.0",
		"vite-plugin-bundle-dts": "0.4.0",
		"vitest": "4.1.9"
